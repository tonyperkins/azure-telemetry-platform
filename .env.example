# =============================================================================
# azure-telemetry-platform — Environment Variables Reference
#
# Copy this file to .env.local (never commit .env.local to source control).
# In Azure, all secrets are stored in Key Vault and referenced via
# @Microsoft.KeyVault(SecretUri=...) in App Service / Function App settings.
# These environment variables are for LOCAL DEVELOPMENT ONLY.
# =============================================================================

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# SQL Server connection string.
# Local dev: use SQL Express / LocalDB (no password required).
# Azure:     resolved from Key Vault at runtime via Managed Identity.
SQL_CONNECTION_STRING="Server=(localdb)\mssqllocaldb;Database=TelemetryDev;Trusted_Connection=True;"

# ---------------------------------------------------------------------------
# TelemetryApi (App Service)
# ---------------------------------------------------------------------------

# Name of the Azure Key Vault (used to build the vault URI at startup).
# Leave blank for local development — connection string is read from config directly.
KEY_VAULT_NAME=""

# Application Insights connection string (includes ingestion endpoint).
# Prefer connection string over instrumentation key — supports private link.
# Leave blank locally to disable telemetry during development.
APPINSIGHTS_CONNECTION_STRING=""

# Comma-separated list of allowed CORS origins (Static Web App hostname in prod).
# Example: https://my-dashboard.azurestaticapps.net
ALLOWED_ORIGINS="http://localhost:5173"

# ---------------------------------------------------------------------------
# MetroIngestion (Azure Function)
# ---------------------------------------------------------------------------

# Capital Metro GTFS-RT protobuf feed URL.
# Default value works for anonymous access; no API key required.
METRO_FEED_URL="https://data.texas.gov/download/r4v4-vz24/application%2Foctet-stream"

# ---------------------------------------------------------------------------
# FlightIngestion (Azure Function)
# ---------------------------------------------------------------------------

# OpenSky Network bounding box: "lamin,lomin,lamax,lomax"
# Default covers greater Austin, TX area.
OPENSKY_BBOX="29.8,-98.2,30.8,-97.2"

# Whether to filter out aircraft that are on the ground (true/false).
# Set to false to include ground traffic at Austin-Bergstrom (AUS).
FILTER_ON_GROUND="true"

# ---------------------------------------------------------------------------
# Dashboard (React Vite dev server)
# ---------------------------------------------------------------------------

# TelemetryApi base URL for the dashboard to poll.
# In production this is the App Service hostname injected at build time.
VITE_API_BASE_URL="http://localhost:5000"
